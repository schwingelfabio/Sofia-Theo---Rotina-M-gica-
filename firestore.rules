rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isHardcodedAdmin() {
      return isSignedIn() && (request.auth.token.email == 'fabiopalacioschwingel@gmail.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt']) && 
             data.keys().size() == 3 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['hearts', 'completedRoutines', 'language', 'activeCharacter', 'updatedAt', 'customization']) &&
             data.keys().size() == 6 &&
             data.hearts is number &&
             data.completedRoutines is list && data.completedRoutines.size() <= 100 &&
             data.language in ['pt', 'en'] &&
             data.activeCharacter in ['sofia', 'theo'] &&
             data.customization is map &&
             data.customization.keys().hasAll(['sofia', 'theo']) &&
             data.customization.sofia is map &&
             data.customization.sofia.keys().hasAll(['outfit', 'accessory']) &&
             data.customization.sofia.outfit is string &&
             data.customization.sofia.accessory is string &&
             data.customization.theo is map &&
             data.customization.theo.keys().hasAll(['outfit', 'accessory']) &&
             data.customization.theo.outfit is string &&
             data.customization.theo.accessory is string &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isHardcodedAdmin() || isAdmin();
      
      allow create: if isOwner(userId) && 
                       isValidId(userId) && 
                       isValidUser(incoming()) && 
                       incoming().role == 'user' && 
                       incoming().createdAt == request.time;
                       
      allow update: if isOwner(userId) && 
                       isValidId(userId) && 
                       isValidUser(incoming()) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['email']) &&
                       incoming().role == existing().role &&
                       incoming().createdAt == existing().createdAt ||
                       isHardcodedAdmin() || isAdmin();
                       
      match /progress/{progressId} {
        allow read: if isOwner(userId) || isHardcodedAdmin() || isAdmin();
        
        allow create: if isOwner(userId) &&
                         isValidId(progressId) &&
                         isValidProgress(incoming()) &&
                         incoming().updatedAt == request.time &&
                         exists(/databases/$(database)/documents/users/$(userId));
                         
        allow update: if isOwner(userId) &&
                         isValidId(progressId) &&
                         isValidProgress(incoming()) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['hearts', 'completedRoutines', 'language', 'activeCharacter', 'updatedAt', 'customization']) &&
                         incoming().updatedAt == request.time ||
                         isHardcodedAdmin() || isAdmin();
      }
    }
  }
}
