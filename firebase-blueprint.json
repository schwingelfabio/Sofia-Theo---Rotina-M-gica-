{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile identifying members and admins.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "GameProgress": {
      "title": "Game Progress",
      "description": "The child's game progress including routines and hearts.",
      "type": "object",
      "properties": {
        "hearts": { "type": "number" },
        "completedRoutines": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["pt", "en"] },
        "sensoryMode": { "type": "string", "enum": ["normal", "simplified"] },
        "activeCharacter": { "type": "string", "enum": ["sofia", "theo"] },
        "customization": {
          "type": "object",
          "properties": {
            "sofia": {
              "type": "object",
              "properties": {
                "outfit": { "type": "string" },
                "accessory": { "type": "string" }
              }
            },
            "theo": {
              "type": "object",
              "properties": {
                "outfit": { "type": "string" },
                "accessory": { "type": "string" }
              }
            }
          }
        },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["hearts", "completedRoutines", "language", "sensoryMode", "activeCharacter", "customization", "updatedAt"]
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "Log of interaction events",
      "type": "object",
      "properties": {
        "event": { "type": "string" },
        "zone": { "type": "string" },
        "timestamp": { "type": "number" },
        "meta": { "type": "object" }
      },
      "required": ["event", "timestamp"]
    },
    "SafetyLog": {
      "title": "Safety Event Log",
      "description": "Log of SOS/Breathing events",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "zone": { "type": "string" },
        "duration": { "type": "number" }
      },
      "required": ["timestamp", "zone", "duration"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Public/base user profile data"
    },
    "users/{userId}/progress/main": {
      "schema": { "$ref": "#/entities/GameProgress" },
      "description": "User game progress"
    },
    "users/{userId}/analytics/{eventId}": {
      "schema": { "$ref": "#/entities/AnalyticsEvent" },
      "description": "Interaction logs"
    },
    "users/{userId}/safety_logs/{logId}": {
      "schema": { "$ref": "#/entities/SafetyLog" },
      "description": "SOS trigger emergency logs"
    }
  }
}
